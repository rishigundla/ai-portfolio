{
  "name": "@rishi/design-system",
  "version": "0.1.0",
  "private": true,
  "description": "Design system for the AI Portfolio monorepo. Tokens, primitives, and AI-specific components extracted from rishikeshgundla.com portfolio site.",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./tokens": "./src/tokens/index.css",
    "./tokens/typed": "./src/tokens/index.ts",
    "./tailwind.config": "./tailwind.config.ts",
    "./lib/cn": "./src/lib/cn.ts",
    "./primitives": "./src/primitives/index.ts",
    "./primitives/*": "./src/primitives/*.tsx",
    "./components": "./src/components/index.ts",
    "./components/*": "./src/components/*.tsx",
    "./motion": "./src/motion/index.ts",
    "./theme": "./src/theme/index.ts",
    "./theme/*": "./src/theme/*.tsx"
  },
  "scripts": {
    "lint": "eslint src",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/source-serif-4": "^5.2.9",
    "@fontsource/space-grotesk": "^5.2.10",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.469.0",
    "react-markdown": "^9.0.3",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^2.5.5"
  },
  "peerDependencies": {
    "next": ">=15",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2"
  }
}
